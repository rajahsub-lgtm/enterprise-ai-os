    "service_topology",
    "telemetry_symptoms",
    "root_cause_service",
    "root_cause_indicator",
    "fault_type",
    "time_window"
  ],
  "synthetic_augmentation_fields": [
    "SyntheticIncident",
    "SyntheticAlert",
    "SyntheticProblem",
    "SyntheticChange",
    "SyntheticKnownError",
    "SyntheticKnowledgeArticle",
    "SyntheticBusinessImpactRecord",
    "SyntheticSupportGroup",
    "SyntheticOwnershipRecord"
  ],
  "anti_circularity_rules": {
    "root_cause_labels_from_synthetic_generator_allowed": false,
    "benchmark_scoring_against_kb_content_allowed": false,
    "cluster_membership_source": "deterministic scenario composition using source_failure_case_id",
    "root_cause_source": "RCAEval-derived root_cause_service and root_cause_indicator",
    "knowledge_base_role": "governed evidence source, not answer key"
