    "policy_id": "POL-KNOWLEDGE-SUPPORT-001",
    "policy_name": "Support Knowledge for Operational Troubleshooting",
    "description": "Operational troubleshooting and support investigations may use Support Knowledge, Wiki Knowledge, and Self-Help Knowledge when appropriate controls are applied.",
